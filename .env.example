# الهوية العامة (الرابط ليس سرًا)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_X_URL=https://x.com/aale1164?s=20
DEMO_MODE=true

# Supabase - أنشئ مشروعًا ثم ضع القيم هنا
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OWNER_EMAIL=

# حماية بصمة الزائر والتوقيع - أنشئ قيمة عشوائية طويلة في الإنتاج
VISITOR_HMAC_SECRET=
ANONYMOUS_FREE_RUNS=3

# Cloudflare Turnstile (اختياري في التطوير، موصى به في الإنتاج)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# مزود إزالة الخلفية - remove.bg في الإصدار الأول
BACKGROUND_REMOVAL_PROVIDER=remove-bg
REMOVE_BG_API_KEY=

# خصائص مستقبلية
MARKETPLACE_ENABLED=false
DEVELOPER_API_ENABLED=false

# SMTP اختياري - تتم إدارة رسائل المصادقة من Supabase افتراضيًا
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="منصة آفاق الرقمية <noreply@example.com>"
